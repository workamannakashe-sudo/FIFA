# SafePass 2026 — Environment Variables Template
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit .env to git — it is blocked by .gitignore
#
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini API Key (required for AI features)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Server settings (optional — defaults shown)
HOST=127.0.0.1
PORT=8000
DEBUG=True

# Security / Rate Limiting (optional — defaults shown)
RATE_LIMIT_WINDOW=60      # seconds per rate-limit window
RATE_LIMIT_MAX=100        # max requests per IP per window
